{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://smart-hospital-management-0xw5.onrender.com/api/$1" },
    { "source": "/uploads/(.*)", "destination": "https://smart-hospital-management-0xw5.onrender.com/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
